z.read("xl/_rels/workbook.xml.rels")
    )

    rmap={
        x.attrib["Id"]:x.attrib["Target"]
        for x in rel
    }


    wb=ET.fromstring(
        z.read("xl/workbook.xml")
    )


    for s in wb.find("a:sheets",ns):

        name=s.attrib["name"]

        rid=s.attrib[
        "{http://schemas.openxmlformats.org/officeDocument/2006/relationships}id"
        ]

        sheet="xl/"+rmap[rid]


        total=0


        # sheet本體
        if sheet in files:
            total+=z.getinfo(sheet).file_size


        # sheet關聯檔
        relfile=sheet.replace(
            "worksheets/",
            "worksheets/_rels/"
        )+".rels"


        if relfile in files:

            rr=ET.fromstring(
                z.read(relfile)
            )

            for x in rr:

                target=x.attrib["Target"]

                path=os.path.normpath(
                    os.path.dirname(relfile)
                    +"/../"
                    +target
                )

                path=path.replace("\\","/")

                if path in files:
                    total+=z.getinfo(path).file_size


        data.append(
            [name,total/1024/1024]
        )



